@page
@model WebApplication24_02.Pages.Categories.IndexModel
@{
    ViewData["Title"] = "Categorías";
}
<h1>CRUD de Categorías</h1>
<a asp-page="Create" class="btn btn-success mb-3">Crear Nueva Categoría</a>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Nombre</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Categories)
    {
        <tr>
            <td>@item.Name</td>
            <td>
                <a asp-page="Edit" asp-route-id="@item.CategoryId" class="btn btn-sm btn-primary">Editar</a>
                <a asp-page="Details" asp-route-id="@item.CategoryId" class="btn btn-sm btn-info">Detalles</a>
                <a asp-page="Delete" asp-route-id="@item.CategoryId" class="btn btn-sm btn-danger">Eliminar</a>
            </td>
        </tr>
    }
    </tbody>
</table>
<a class="nav-link text-dark" asp-page="/Index">Home</a>
<a class="nav-link text-dark" asp-page="/Privacy">Privacy</a>
