@page
@model WebApplication24_02.Pages.Products.DetailsModel
@{
    ViewData["Title"] = "Detalles de Producto";
}
<h2>Detalles de Producto</h2>
<dl class="row">
    <dt class="col-sm-2">Nombre</dt>
    <dd class="col-sm-10">@Model.Product.Name</dd>
    <dt class="col-sm-2">Precio</dt>
    <dd class="col-sm-10">@Model.Product.Price</dd>
    <dt class="col-sm-2">Categoría</dt>
    <dd class="col-sm-10">@Model.Product.CategoryName</dd>
</dl>
<a asp-page="Edit" asp-route-id="@Model.Product.ProductId" class="btn btn-primary">Editar</a>
<a asp-page="Index" class="btn btn-secondary">Volver</a>
