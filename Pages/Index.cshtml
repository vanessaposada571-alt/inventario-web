@page
@{
    ViewData["Title"] = "Inventario Web";
}

<div class="container py-5">
    <div class="inventory-hero mb-4">
        <h1 class="mt-2 mb-3" style="font-weight:700; letter-spacing:-1px;">Bienvenido al Inventario Web</h1>
        <p class="mb-4 text-secondary">Accede fácilmente a las opciones principales del sistema:</p>
        <div class="row g-3">
            <div class="col-12 col-md-6 col-lg-3">
                <a asp-page="/Products/Index" class="btn btn-primary w-100 py-2"><i class="bi bi-box"></i> Productos</a>
            </div>
            <div class="col-12 col-md-6 col-lg-3">
                <a asp-page="/Categories/Index" class="btn btn-success w-100 py-2"><i class="bi bi-tags"></i>Categor&iacute;as</a>
            </div>
            <div class="col-12 col-md-6 col-lg-3">
                <a asp-page="/Customers/Index" class="btn btn-info w-100 py-2"><i class="bi bi-people"></i> Clientes</a>
            </div>
            <div class="col-12 col-md-6 col-lg-3">
                <a asp-page="/Orders/Index" class="btn btn-warning w-100 py-2"><i class="bi bi-cart"></i> Pedidos</a>
            </div>
        </div>
    </div>
</div>
