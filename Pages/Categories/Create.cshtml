@page
@model WebApplication24_02.Pages.Categories.CreateModel
@{
    ViewData["Title"] = "Crear Categoría";
}
<h2>Crear Categor&iacute;a</h2>
<form method="post" class="mt-3">
    <div class="mb-3">
        <label asp-for="Category.Name" class="form-label"></label>
        <input asp-for="Category.Name" class="form-control" />
        <span asp-validation-for="Category.Name" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Crear</button>
    <a asp-page="Index" class="btn btn-secondary">Cancelar</a>
</form>
