@page
@model WebApplication24_02.Pages.Categories.DeleteModel
@{
    ViewData["Title"] = "Eliminar Categoría";
}
<h2>Eliminar Categoría</h2>
<div class="alert alert-warning">¿Estás seguro de que deseas eliminar esta categoría?</div>
<dl class="row">
    <dt class="col-sm-2">Nombre</dt>
    <dd class="col-sm-10">@Model.Category.Name</dd>
</dl>
<form method="post">
    <input type="hidden" asp-for="Category.CategoryId" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-page="Index" class="btn btn-secondary">Cancelar</a>
</form>
