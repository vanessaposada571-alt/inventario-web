@page
@model WebApplication24_02.Pages.Orders.CreateModel
@{
    ViewData["Title"] = "Crear Pedido";
}
<h2>Crear Pedido</h2>
<form method="post">
    <div class="mb-3">
        <label asp-for="Order.CustomerId" class="form-label">Cliente</label>
        <select asp-for="Order.CustomerId" class="form-select" asp-items="Model.CustomerOptions"></select>
        <span asp-validation-for="Order.CustomerId" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label class="form-label">Productos</label>
        <!-- Asegúrate de que SelectedProductIds coincida con el nombre en tu archivo .cs -->
        <select asp-for="SelectedProductIds" class="form-select" multiple size="6">
            @foreach (var p in Model.ProductOptions)
            {
                <option value="@p.Value">@p.Text</option>
            }
        </select>
        <span class="form-text">Mantén presionada la tecla Ctrl (o Cmd) para seleccionar varios productos.</span>
    </div>
    <button type="submit" class="btn btn-success"><i class="bi bi-check-circle"></i> Guardar</button>
    <a asp-page="Index" class="btn btn-secondary">Cancelar</a>
</form>
