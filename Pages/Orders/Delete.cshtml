@page
@model WebApplication24_02.Pages.Orders.DeleteModel
@{
    ViewData["Title"] = "Eliminar Pedido";
}
<h2>Eliminar Pedido</h2>
<div class="alert alert-warning">
    <strong>¿Estás seguro que deseas eliminar este pedido?</strong>
</div>
<div>
    <dl class="row">
        <dt class="col-sm-2">Cliente</dt>
        <dd class="col-sm-10">@Model.Order.Customer?.Name</dd>
        <dt class="col-sm-2">Fecha</dt>
        <dd class="col-sm-10">@Model.Order.OrderDate.ToString("yyyy-MM-dd")</dd>
        <dt class="col-sm-2">Productos</dt>
        <dd class="col-sm-10">
            @if (Model.Order.Products != null && Model.Order.Products.Any())
            {
                <ul>
                @foreach (var p in Model.Order.Products)
                {
                    <li>@p.Name (@p.Price.ToString("C"))</li>
                }
                </ul>
            }
            else
            {
                <span class="text-muted">Sin productos</span>
            }
        </dd>
    </dl>
    <form method="post">
        <input type="hidden" asp-for="Order.OrderId" />
        <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Eliminar</button>
        <a asp-page="Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>
