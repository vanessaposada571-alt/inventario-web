@page
@model WebApplication24_02.Pages.Products.IndexModel
@{
    ViewData["Title"] = "Productos";
}
<h1>Gestión de Productos</h1>
<a asp-page="Create" class="btn btn-success mb-3">Crear Nuevo Producto</a>
<table class="table table-striped">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Precio</th>
            <th>Categoría</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model.Products)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Price.ToString("C")</td>
            <td>@item.Category?.Name</td>
            <td>
                <a asp-page="Edit" asp-route-id="@item.ProductId" class="btn btn-sm btn-primary">Editar</a>
                <a asp-page="Details" asp-route-id="@item.ProductId" class="btn btn-sm btn-info">Detalles</a>
                <a asp-page="Delete" asp-route-id="@item.ProductId" class="btn btn-sm btn-danger">Eliminar</a>
            </td>
        </tr>
    }
    </tbody>
</table>
<a class="nav-link text-dark" asp-page="/Index">Home</a>
<a class="nav-link text-dark" asp-page="/Privacy">Privacy</a>
