@page
@model WebApplication24_02.Pages.Customers.IndexModel
@{
    ViewData["Title"] = "Clientes";
}
<div class="inventory-hero mb-4">
    <div class="d-flex justify-content-between align-items-center flex-wrap">
        <h1 class="mb-0"><i class="bi bi-people"></i> Gestión de Clientes</h1>
        <a asp-page="Create" class="btn btn-success btn-lg"><i class="bi bi-plus-circle"></i> Nuevo Cliente</a>
    </div>
</div>
<div class="table-responsive">
    <table class="table table-bordered table-hover shadow-sm">
        <thead class="table-light">
            <tr>
                <th>Id</th>
                <th>Nombre</th>
                <th>Teléfono</th>
                <th>Dirección</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model.Customers)
        {
            <tr>
                <td class="align-middle">@item.CustomerId</td>
                <td class="align-middle">@item.Name</td>
                <td class="align-middle">@item.Phone</td>
                <td class="align-middle">@item.Address</td>
                <td class="align-middle">
                    <div class="btn-group" role="group">
                        <a asp-page="Edit" asp-route-id="@item.CustomerId" class="btn btn-outline-primary btn-sm" title="Editar"><i class="bi bi-pencil-square"></i></a>
                        <a asp-page="Details" asp-route-id="@item.CustomerId" class="btn btn-outline-info btn-sm" title="Detalles"><i class="bi bi-info-circle"></i></a>
                        <a asp-page="Delete" asp-route-id="@item.CustomerId" class="btn btn-outline-danger btn-sm" title="Eliminar"><i class="bi bi-trash"></i></a>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
<a class="nav-link text-dark" asp-page="/Index">Home</a>
