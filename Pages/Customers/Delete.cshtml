@page
@model WebApplication24_02.Pages.Customers.DeleteModel
@{
    ViewData["Title"] = "Eliminar Cliente";
}
<h2>Eliminar Cliente</h2>
<div class="alert alert-warning">
    <strong>¿Estás seguro que deseas eliminar este cliente?</strong>
</div>
<div>
    <dl class="row">
        <dt class="col-sm-2">Nombre</dt>
        <dd class="col-sm-10">@Model.Customer.Name</dd>
        <dt class="col-sm-2">Teléfono</dt>
        <dd class="col-sm-10">@Model.Customer.Phone</dd>
        <dt class="col-sm-2">Dirección</dt>
        <dd class="col-sm-10">@Model.Customer.Address</dd>
    </dl>
    <form method="post">
        <input type="hidden" asp-for="Customer.CustomerId" />
        <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Eliminar</button>
        <a asp-page="Index" class="btn btn-secondary">Cancelar</a>
    </form>
</div>
